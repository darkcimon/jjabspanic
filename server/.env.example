STABILITY_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PORT=3000
IMAGE_BASE_URL=http://localhost:3000/images
IMAGE_DIR=./public/images

# JWT (카카오 로그인 후 발급하는 세션 토큰 서명 키 — 32자 이상 임의 문자열)
JWT_SECRET=change_me_to_a_long_random_string_32chars_or_more

# 카카오 OAuth 2.0 (https://developers.kakao.com 에서 앱 생성 후 발급)
KAKAO_CLIENT_ID=your_kakao_rest_api_key
KAKAO_REDIRECT_URI=http://localhost:3000/auth/kakao/callback

# 토스페이먼츠 (https://developers.tosspayments.com 에서 발급)
# 테스트 키: test_sk_... / test_ck_...  |  운영 키: live_sk_... / live_ck_...
TOSS_SECRET_KEY=test_sk_xxxxxxxxxxxxxxxxxxxxxxxx
TOSS_CLIENT_KEY=test_ck_xxxxxxxxxxxxxxxxxxxxxxxx
